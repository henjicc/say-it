{
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "说吧！",
        "width": 1080,
        "height": 860,
        "center": true,
        "resizable": true,
        "visible": false,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "targets": ["nsis"],
    "resources": [
      "resources/ocr/**/*",
      "resources/licenses/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  }
}
