{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "说吧！",
  "mainBinaryName": "SayIt",
  "version": "0.3.0",
  "identifier": "com.henjicc.sayit",
  "build": {
    "devUrl": "http://localhost:5155",
    "beforeDevCommand": "npm run ui:dev",
    "beforeBuildCommand": "npm run ui:build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "说吧！",
        "width": 1080,
        "height": 860,
        "center": true,
        "resizable": true,
        "visible": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "publisher": "痕继痕迹",
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  }
}
